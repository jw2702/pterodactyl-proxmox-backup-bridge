# Copy to .env and fill in. All BRIDGE_* values are the bridge's own
# configuration; all PBS_* values are passed straight through to
# proxmox-backup-client (it reads them itself).

# --- S3-facing credentials (put these into Pterodactyl Panel's S3 disk config) ---
BRIDGE_ACCESS_KEY=changeme-access-key
BRIDGE_SECRET_KEY=changeme-secret-key-please-use-something-long-and-random
BRIDGE_REGION=us-east-1

# --- HTTP server ---
BRIDGE_LISTEN_ADDR=:8080
BRIDGE_CLOCK_SKEW_SECONDS=900

# --- Local storage (mount as volumes in Docker; see docker-compose.example.yml) ---
BRIDGE_DATA_DIR=/var/lib/bridge/data
BRIDGE_SCRATCH_DIR=/var/lib/bridge/scratch
BRIDGE_MULTIPART_TTL_HOURS=24
BRIDGE_GC_INTERVAL_MINUTES=30

# --- Proxmox Backup Server connection ---
# Format: <user>@<realm>:<datastore>  or with an API token: <user>@<realm>!<tokenname>@<datastore>
PBS_REPOSITORY=backup-user@pbs!bridge-token@pbs.example.com:datastore1
# Either PBS_PASSWORD (user password or API token secret) ...
PBS_PASSWORD=
# ... or set BRIDGE_PBS_API_TOKEN below (kept as a separate variable for
# clarity; the bridge passes whichever is set to the client as PBS_PASSWORD).
PBS_API_TOKEN=
# Required if the PBS server uses a self-signed certificate (get it from
# the PBS web UI under Dashboard -> Certificates, or via
# `proxmox-backup-manager cert info`).
PBS_FINGERPRINT=

BRIDGE_PBS_BACKUP_TYPE=host
BRIDGE_PBS_COMMAND_TIMEOUT_SECONDS=3600

# --- Logging ---
BRIDGE_LOG_LEVEL=info
BRIDGE_LOG_FORMAT=json
